<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp3.MainPage">

    <ContentPage.Resources>
        <Style x:Key="GameButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="48"/>
            <Setter Property="TextColor" Value="White"/>
            <Setter Property="BackgroundColor" Value="#2C3E50"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
    </ContentPage.Resources>
    <Grid
        RowDefinitions="*,*,*"
        ColumnDefinitions="*,*,*"
        Padding="20"
        RowSpacing="5"
        ColumnSpacing="5" >

        <Button x:Name="Button11"  Grid.Row="0" Grid.Column="0" Style="{StaticResource GameButtonStyle}" Clicked="Cell_Clicked"/>
        <Button x:Name="Button12" Grid.Row="0" Grid.Column="1" Style="{StaticResource GameButtonStyle}" Clicked="Cell_Clicked"/>
        <Button x:Name="Button13" Grid.Row="0" Grid.Column="2" Style="{StaticResource GameButtonStyle}" Clicked="Cell_Clicked"/>

        <Button x:Name="Button21" Grid.Row="1" Grid.Column="0" Style="{StaticResource GameButtonStyle}" Clicked="Cell_Clicked"/>
        <Button x:Name="Button22" Grid.Row="1" Grid.Column="1" Style="{StaticResource GameButtonStyle}" Clicked="Cell_Clicked"/>
        <Button x:Name="Button23" Grid.Row="1" Grid.Column="2" Style="{StaticResource GameButtonStyle}" Clicked="Cell_Clicked"/>

        <Button x:Name="Button31" Grid.Row="2" Grid.Column="0" Style="{StaticResource GameButtonStyle}" Clicked="Cell_Clicked"/>
        <Button x:Name="Button32" Grid.Row="2" Grid.Column="1" Style="{StaticResource GameButtonStyle}" Clicked="Cell_Clicked"/>
        <Button x:Name="Button33" Grid.Row="2" Grid.Column="2" Style="{StaticResource GameButtonStyle}" Clicked="Cell_Clicked"/>
    </Grid>
</ContentPage>
